# Marketing Engine Configuration
# Copy to .env and fill in your values

# ── Database (auto-configured by docker-compose) ──────────
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/marketing
# REDIS_URL=redis://redis:6379/0

# ── LLM / AI ─────────────────────────────────────────────
LITELLM_URL=http://host.docker.internal:4000
LITELLM_MODEL=coder
LITELLM_LIGHT_MODEL=light
LITELLM_CREATIVE_MODEL=creative

# ── Faceless Video ────────────────────────────────────────
PEXELS_API_KEY=
HEYGEN_API_KEY=
ELEVENLABS_API_KEY=

# ── YouTube Upload ────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Reddit ────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=MarketingEngine/1.0

# ── Meta (Facebook/Instagram) Ads ────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── Google Ads ────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ── TikTok Ads ───────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ── Landing Pages ────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ── Content Calendar ─────────────────────────────────────
DAILY_POSTS_TARGET=3
REDDIT_CHECK_INTERVAL_MINUTES=30
AD_OPTIMIZE_INTERVAL_HOURS=6

# ── Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8300
